#!/usr/bin/env python3
# live_fix.py — image-based flags (render everywhere) + live fixture pinning.
import os, re, sys

if not os.path.exists("package.json"):
    sys.exit("Run from the repo root (no package.json here).")

def backup(p):
    b = p + ".bak2"
    if not os.path.exists(b) and os.path.exists(p):
        open(b, "w", encoding="utf-8").write(open(p, encoding="utf-8").read())

changed, skipped = [], []

# ---------------------------------------------------------------------------
# 1. Rewrite flags.js -> name maps to ISO code, getFlag() returns an <img>.
# ---------------------------------------------------------------------------
FLAGS_JS = r'''// frontend/src/services/flags.js — image flags (flagcdn.com), render on every OS.
// Emoji flags don't render on Windows/many Linux setups, so we use <img> instead.

const FLAG_CODES = {
  // CONMEBOL
  "Argentina":"ar","Brazil":"br","Colombia":"co","Uruguay":"uy","Ecuador":"ec",
  "Paraguay":"py","Venezuela":"ve","Chile":"cl","Bolivia":"bo","Peru":"pe",
  // UEFA
  "France":"fr","England":"gb-eng","Spain":"es","Portugal":"pt","Germany":"de",
  "Netherlands":"nl","Belgium":"be","Switzerland":"ch","Croatia":"hr","Austria":"at",
  "Norway":"no","Scotland":"gb-sct","Wales":"gb-wls","Denmark":"dk","Poland":"pl",
  "Serbia":"rs","Sweden":"se","Hungary":"hu","Romania":"ro","Ukraine":"ua",
  "Turkey":"tr","Turkiye":"tr","Czech Republic":"cz","Slovakia":"sk",
  "Bosnia and Herzegovina":"ba","Albania":"al","Slovenia":"si","Greece":"gr","Georgia":"ge",
  // CONCACAF
  "USA":"us","United States":"us","Canada":"ca","Mexico":"mx","Costa Rica":"cr",
  "Honduras":"hn","Panama":"pa","Jamaica":"jm","Cuba":"cu","Trinidad and Tobago":"tt",
  "Curacao":"cw","Cura\u00e7ao":"cw","El Salvador":"sv","Guatemala":"gt","Haiti":"ht",
  // CAF
  "Morocco":"ma","Senegal":"sn","Egypt":"eg","Nigeria":"ng","Ghana":"gh","Cameroon":"cm",
  "Ivory Coast":"ci","Algeria":"dz","Tunisia":"tn","Mali":"ml","South Africa":"za",
  "Congo DR":"cd","DR Congo":"cd","Democratic Republic of Congo":"cd",
  "Cape Verde":"cv","Cabo Verde":"cv","Zambia":"zm","Tanzania":"tz","Uganda":"ug",
  // AFC
  "Japan":"jp","South Korea":"kr","Korea Republic":"kr","Saudi Arabia":"sa","Iran":"ir",
  "Australia":"au","Qatar":"qa","Iraq":"iq","Jordan":"jo","Uzbekistan":"uz","China":"cn",
  "India":"in","Vietnam":"vn","Thailand":"th","Myanmar":"mm","Indonesia":"id",
  "Philippines":"ph","Bahrain":"bh","UAE":"ae","United Arab Emirates":"ae","Oman":"om",
  "Kuwait":"kw","Palestine":"ps","Lebanon":"lb",
  // OFC
  "New Zealand":"nz","Fiji":"fj","Papua New Guinea":"pg","Solomon Islands":"sb","Vanuatu":"vu",
};

function _codeFor(teamName) {
  if (!teamName) return null;
  if (FLAG_CODES[teamName]) return FLAG_CODES[teamName];
  const lower = teamName.trim().toLowerCase();
  const exact = Object.keys(FLAG_CODES).find(k => k.toLowerCase() === lower);
  if (exact) return FLAG_CODES[exact];
  // conservative partial: a known name fully contained in the feed's name
  const part = Object.keys(FLAG_CODES).find(k => lower.includes(k.toLowerCase()));
  return part ? FLAG_CODES[part] : null;
}

// Returns an <img> tag string (or a ball emoji if the team is unknown).
function getFlag(teamName) {
  const code = _codeFor(teamName);
  if (!code) return "\u26bd";
  const url = "https://flagcdn.com/" + code + ".svg";
  return '<img src="' + url + '" alt="' + (teamName || "") +
         '" loading="lazy" ' +
         'style="width:32px;height:22px;border-radius:3px;object-fit:cover;' +
         'vertical-align:middle;box-shadow:0 0 0 1px rgba(0,0,0,0.15);">';
}
'''

fp = "frontend/src/services/flags.js"
cur = open(fp, encoding="utf-8").read() if os.path.exists(fp) else ""
if "flagcdn.com" in cur:
    skipped.append("flags.js (already image-based)")
else:
    backup(fp)
    open(fp, "w", encoding="utf-8").write(FLAGS_JS)
    changed.append("flags.js (emoji -> image flags)")

# ---------------------------------------------------------------------------
# 2. MatchView.js — flags are now HTML, use innerHTML not textContent.
# ---------------------------------------------------------------------------
mv = "frontend/src/components/MatchView.js"
t = open(mv, encoding="utf-8").read()
before = t
t = t.replace(
    'if (homeFlagEl) homeFlagEl.textContent = typeof getFlag === "function" ? getFlag(homeTeam) : "\u26bd";',
    'if (homeFlagEl) homeFlagEl.innerHTML = typeof getFlag === "function" ? getFlag(homeTeam) : "\u26bd";')
t = t.replace(
    'if (awayFlagEl) awayFlagEl.textContent = typeof getFlag === "function" ? getFlag(awayTeam) : "\u26bd";',
    'if (awayFlagEl) awayFlagEl.innerHTML = typeof getFlag === "function" ? getFlag(awayTeam) : "\u26bd";')
if t == before:
    if "innerHTML = typeof getFlag" in before:
        skipped.append("MatchView.js (already innerHTML)")
    else:
        skipped.append("MatchView.js (flag lines not found — CHECK MANUALLY)")
else:
    backup(mv)
    open(mv, "w", encoding="utf-8").write(t)
    changed.append("MatchView.js (textContent -> innerHTML for flags)")

# ---------------------------------------------------------------------------
# 3. server.js — opt-in fixture pinning via FEATURED_FIXTURE_ID.
# ---------------------------------------------------------------------------
sv = "backend/server.js"
s = open(sv, encoding="utf-8").read()
if "FEATURED_FIXTURE_ID" in s:
    skipped.append("server.js (fixture pinning already present)")
else:
    ok = True
    anchor_var = "let connectedPlayers   = 0;"
    if anchor_var in s:
        s = s.replace(anchor_var, anchor_var +
            "\nconst FEATURED_FIXTURE_ID = process.env.FEATURED_FIXTURE_ID"
            " ? String(process.env.FEATURED_FIXTURE_ID) : null;")
    else:
        ok = False
    anchor_odds = "  const prob = extractProbability(oddsData);\n  if (!prob) return;"
    if anchor_odds in s:
        s = s.replace(anchor_odds, anchor_odds +
            "\n  if (FEATURED_FIXTURE_ID && String(prob.fixtureId) !== FEATURED_FIXTURE_ID) return;")
    else:
        ok = False
    anchor_scores = "  const fid     = scoresData.FixtureId || scoresData.fixture_id;"
    if anchor_scores in s:
        s = s.replace(anchor_scores, anchor_scores +
            "\n  if (FEATURED_FIXTURE_ID && fid != null && String(fid) !== FEATURED_FIXTURE_ID) return;")
    else:
        ok = False
    if ok:
        backup(sv)
        open(sv, "w", encoding="utf-8").write(s)
        changed.append("server.js (opt-in FEATURED_FIXTURE_ID pinning)")
    else:
        skipped.append("server.js (an anchor was not found — CHECK MANUALLY)")

# ---------------------------------------------------------------------------
# 4. .env.example — document FEATURED_FIXTURE_ID.
# ---------------------------------------------------------------------------
ev = ".env.example"
if os.path.exists(ev):
    e = open(ev, encoding="utf-8").read()
    if "FEATURED_FIXTURE_ID" not in e:
        backup(ev)
        e += "\n# Pin the app to ONE match (get the id from: node explore-api.js).\n# Leave blank to auto-follow whatever fixture last emitted.\nFEATURED_FIXTURE_ID=\n"
        open(ev, "w", encoding="utf-8").write(e)
        changed.append(".env.example (documented FEATURED_FIXTURE_ID)")
    else:
        skipped.append(".env.example (already documents FEATURED_FIXTURE_ID)")

print("\n=== CHANGED ===")
[print("  +", c) for c in changed]
print("\n=== SKIPPED ===")
[print("  -", s) for s in skipped]
print("\nBackups: <file>.bak2. Set FEATURED_FIXTURE_ID in .env to pin one match.")
